generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Poll {
  id          Int     @id @default(autoincrement())
  authority   String
  pollId      Int
  question    String
  description String?
  createdAt   BigInt  // unix ms

  // Последнее раскрытие результатов (обновляется при каждом reveal)
  revealedAt     BigInt?   // unix ms — когда в последний раз раскрыли
  yesWins        Boolean?  // true = победил Yes, false = No
  revealSignature String?  // подпись callback-транзакции (опционально)

  @@unique([authority, pollId])
  @@index([authority])
}
